{
  "name": "olchilab-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:mintlify": "vite --config vite.mintlify.config.js",
    "dev:sentry": "vite --config vite.sentry.config.js",
    "dev:stripe": "vite --config vite.stripe.config.js",
    "dev:vercel": "vite --config vite.vercel.config.js",
    "snapshot:promotion": "node scripts/export-promotion-dashboard-snapshot.mjs",
    "build": "vite build",
    "build:github-pages": "vite build --config vite.github-pages.config.js && node scripts/prepare-spa-routes.mjs",
    "build:mintlify": "vite build --config vite.mintlify.config.js",
    "build:sentry": "vite build --config vite.sentry.config.js",
    "build:stripe": "vite build --config vite.stripe.config.js",
    "build:vercel": "vite build --config vite.vercel.config.js",
    "preview": "vite preview --host 127.0.0.1"
  },
  "devDependencies": {
    "vite": "^8.0.16"
  }
}
